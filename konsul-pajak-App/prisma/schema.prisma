// FILE: prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Model Bawaan NextAuth
// =================================
// Model ini WAJIB ada untuk NextAuth.js

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  // --- Relasi custom kita ---
  chats         Chat[]
  feedbacks     Feedback[]
  reports       Report[]
  // --- Sistem Kuota/Kredit ---
  credits           Int       @default(100)    // Sisa kredit pesan
  creditCostPerMsg  Int       @default(1)      // Biaya per pesan (bisa naik jika spam)
  isFlagged         Boolean   @default(false)  // Flag admin untuk user yang menyalahgunakan
  lastMessageAt     DateTime?                  // Untuk deteksi spam (waktu pesan terakhir)
  spamStreak        Int       @default(0)      // Hitungan berturut-turut pesan spam
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  refresh_token_expires_in Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Report {
  id        Int      @id @default(autoincrement())
  userId    String
  messageId Int?     // Optional, if the report is related to a specific message
  content   String   @db.Text
  type      String   // "saran" or "kesalahan"
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 2. Model Custom Aplikasi "Konsul Pajak"
// =========================================
// Ini adalah tabel aplikasi kita, disesuaikan untuk NextAuth.

model Admin {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password_hash String   @db.Text // Ganti dari schema lama, lebih aman
  role          String   @default("admin")
  createdAt     DateTime @default(now())
}

model Chat {
  id        String    @id @default(uuid())
  userId    String
  title     String    @default("Percakapan Baru")
  createdAt DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
}

model Message {
  id        Int       @id @default(autoincrement())
  chatId    String
  role      String    // 'user' atau 'assistant'
  content   String    @db.Text
  sources   Json?     // Menyimpan data sitasi (sources)
  createdAt DateTime  @default(now())

  chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  feedback  Feedback? // Relasi 1-to-1 (optional, karena tidak semua pesan di-rate)
  reports   Report[]

  @@index([chatId])
}

model Feedback {
  id        Int      @id @default(autoincrement())
  messageId Int      @unique // Relasi 1-ke-1 ke Message
  userId    String   // <- Ini sekarang terhubung ke User.id (String CUID)
  rating    String   // 'suka' atau 'tidak_suka'
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: NoAction) // Jangan cascade jika user dihapus

  @@index([userId])
}

model Peraturan {
  id        Int      @id @default(autoincrement())
  title     String
  nomor     String   @unique
  jenis     String   // "Undang-undang", etc.
  topik     String   // "PPh", "PPN", "KUP", "PBB", "BPHTB", "Bea Meterai", "Other", etc.
  tahun     String
  status    String   // "Berlaku", "Diubah atau Disempurnakan", "Dicabut"
  deskripsi String   @default("") @db.Text
  url       String   @default("")
  createdAt DateTime @default(now())

  @@index([jenis])
  @@index([topik])
  @@index([status])
}

// 3. Konfigurasi Kuota (Singleton — hanya 1 baris)
// ==================================================
model QuotaConfig {
  id                    Int    @id @default(1)  // Selalu ID 1 (singleton)
  defaultCredits        Int    @default(100)    // Kredit default untuk user baru
  guestMessageLimit     Int    @default(1)      // Batas pesan untuk guest
  spamTimeWindowSec     Int    @default(30)     // Pesan dalam waktu ini = spam
  minMessageLength      Int    @default(10)     // Pesan lebih pendek dari ini = spam
}